# Google AI Studio API Key (Required for AI features)
# Use VITE_ prefix for Vercel/Vite client-side access
VITE_GEMINI_API_KEY=
GEMINI_API_KEY=

# Firebase Configuration (Optional if using firebase-applet-config.json)
# If you want to use environment variables instead of the JSON file, 
# uncomment and fill these:
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_DATABASE_ID=
